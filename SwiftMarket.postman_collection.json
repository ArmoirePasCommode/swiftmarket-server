{
	"info": {
		"name": "SwiftMarket API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Users",
			"item": [
				{
					"name": "Create User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set(\"userId\", jsonData.id);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"janedoe\",\n    \"email\": \"jane@example.com\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users"
							]
						}
					}
				},
				{
					"name": "List All Users",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users"
							]
						}
					}
				},
				{
					"name": "Get Specific User",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/{{userId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"{{userId}}"
							]
						}
					}
				},
				{
					"name": "Get User Listings",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/users/{{userId}}/listings",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"{{userId}}",
								"listings"
							]
						}
					}
				}
			]
		},
		{
			"name": "Listings",
			"item": [
				{
					"name": "Create Listing",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set(\"listingId\", jsonData.id);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Airpods Pro\",\n    \"description\": \"Noise cancelling headphones\",\n    \"price\": 249.99,\n    \"category\": \"electronics\",\n    \"sellerID\": \"{{userId}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/listings",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"listings"
							]
						}
					}
				},
				{
					"name": "List Paginated Listings",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/listings?page=1&per=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"listings"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "per",
									"value": "10"
								}
							]
						}
					}
				},
				{
					"name": "Search Listings",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/listings?category=electronics&q=Airpods",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"listings"
							],
							"query": [
								{
									"key": "category",
									"value": "electronics"
								},
								{
									"key": "q",
									"value": "Airpods"
								}
							]
						}
					}
				},
				{
					"name": "Get Specific Listing",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/listings/{{listingId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"listings",
								"{{listingId}}"
							]
						}
					}
				},
				{
					"name": "Delete Listing",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/listings/{{listingId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"listings",
								"{{listingId}}"
							]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		},
		{
			"key": "userId",
			"value": ""
		},
		{
			"key": "listingId",
			"value": ""
		}
	]
}
